rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // Documento Petes/{petId} — `resource` e o documento do pet
    function isPetOwner() {
      return isSignedIn() && resource.data.ownerId == request.auth.uid;
    }

    // Leitura do dono a partir de qualquer subcaminho sob o pet
    function isPetOwnerById(petId) {
      return isSignedIn() &&
        get(/databases/$(database)/documents/Pets/$(petId)).data.ownerId == request.auth.uid;
    }

    function isPetSecondaryMemberById(petId) {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/Pets/$(petId)/members/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/Pets/$(petId)/members/$(request.auth.uid)).data.status == "active" &&
        get(/databases/$(database)/documents/Pets/$(petId)/members/$(request.auth.uid)).data.role == "secondary";
    }

    function canReadPetById(petId) {
      return isPetOwnerById(petId) || isPetSecondaryMemberById(petId);
    }

    function canEditPetBasicsById(petId) {
      return isPetOwnerById(petId) ||
        (isPetSecondaryMemberById(petId) &&
          get(/databases/$(database)/documents/Pets/$(petId)/members/$(request.auth.uid)).data.permissions.editBasicData == true);
    }

    // Perfil do tutor e toda arvore sob User/{uid} (ex.: vacinas legado em User/{uid}/vaccines)
    match /User/{uid} {
      allow read, write: if isOwner(uid);
      match /{path=**} {
        allow read, write: if isOwner(uid);
      }
    }

    // Pet e todas as subcolecoes: vacinas, vaccines (legado), activityMinutes,
    // weightEntries, medicationReminders, finderMessages, nfcAccessLogs, etc.
    match /Pets/{petId} {
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      allow read: if canReadPetById(petId);
      allow delete: if isPetOwner();
      // Impede transferir o pet para outro dono
      allow update: if canEditPetBasicsById(petId) && request.resource.data.ownerId == resource.data.ownerId;

      match /members/{memberUid} {
        allow read: if isPetOwnerById(petId) || (isSignedIn() && request.auth.uid == memberUid);
        allow create, update: if isPetOwnerById(petId);
        allow delete: if isPetOwnerById(petId) || (isSignedIn() && request.auth.uid == memberUid);
      }

      match /{collectionId}/{docId} {
        allow read: if collectionId != "members" && canReadPetById(petId);
        allow write: if collectionId != "members" && canEditPetBasicsById(petId);
        match /{path=**} {
          allow read: if collectionId != "members" && canReadPetById(petId);
          allow write: if collectionId != "members" && canEditPetBasicsById(petId);
        }
      }
    }

    // Documento de veterinario: acesso somente ao proprio UID
    match /Veterinarians/{uid} {
      allow read, write: if isOwner(uid);
    }
  }
}
