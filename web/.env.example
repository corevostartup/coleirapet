# Copie para .env.local e ajuste conforme o ambiente.

# ---- Firebase Web (cliente) ----
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
# Opcionais:
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# ---- Firebase Admin (servidor) ----
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
# Mantenha quebras de linha escapadas com \n
FIREBASE_ADMIN_PRIVATE_KEY=

# Callback de auth usado pelo app iOS (ASWebAuthenticationSession)
NEXT_PUBLIC_IOS_AUTH_CALLBACK_SCHEME=coleirapet

# Produção: permitir botão/rota "Acesso dev" (desligado por padrão).
# ENABLE_DEV_AUTH_BYPASS=true

# Forçar desligar bypass dev mesmo em desenvolvimento.
# DISABLE_DEV_AUTH_BYPASS=true
