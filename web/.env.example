# Copie para .env.local e ajuste conforme o ambiente.

# ---- Firebase Web (cliente) ----
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
# Opcionais:
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# ---- Firebase Admin (servidor) ----
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
# Mantenha quebras de linha escapadas com \n
FIREBASE_ADMIN_PRIVATE_KEY=
# ImgBB (somente servidor) — upload da foto do pet no perfil. Chave em https://api.imgbb.com/
# Nunca use NEXT_PUBLIC_* (a chave ficaria exposta ao navegador).
IMGBB_API_KEY=
# Opcional: mesmo valor com alias aceito pela app (deploys que usam outro nome):
# IMGBB_KEY=
# Alternativa recomendada em CI/CD: service account JSON (puro ou base64)
# FIREBASE_ADMIN_SERVICE_ACCOUNT_JSON=

# Compat: callback legado do fluxo /auth/ios/google
NEXT_PUBLIC_IOS_AUTH_CALLBACK_SCHEME=lyka

# Produção: permitir botão/rota "Acesso dev" (desligado por padrão).
# ENABLE_DEV_AUTH_BYPASS=true

# Forçar desligar bypass dev mesmo em desenvolvimento.
# DISABLE_DEV_AUTH_BYPASS=true
